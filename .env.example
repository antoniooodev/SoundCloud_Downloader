# Local runtime mode and logging.
SCD_ENVIRONMENT=development
SCD_LOG_LEVEL=info

# Local data paths used by storage, temp workspaces, and future library data.
SCD_DATA_DIR=data
SCD_TEMP_DIR=data/tmp
SCD_LIBRARY_DIR=data/library

# External I/O limits.
SCD_HTTP_TIMEOUT_SECONDS=30
SCD_HTTP_MAX_RETRIES=3
SCD_HTTP_BACKOFF_BASE_SECONDS=0.5
SCD_MAX_PARALLEL_TRACKS_PER_USER=2
SCD_MAX_PARALLEL_SEGMENTS_PER_TRACK=8

# Policy mode toggles.
SCD_ENABLE_PUBLIC_MODE=true
SCD_ENABLE_GO_PLUS_MODE=true

# Safety gates. Keep false unless you are intentionally running local smoke tests.
SCD_ALLOW_NETWORK=false
SCD_ALLOW_FILESYSTEM_WRITES=false

# Artifact output and temporary workspace roots.
SCD_ARTIFACT_STORAGE_ROOT=data/artifacts
SCD_ARTIFACT_TEMP_ROOT=data/tmp

# ffmpeg discovery and subprocess timeout.
SCD_FFMPEG_BINARY=ffmpeg
SCD_FFMPEG_TIMEOUT_SECONDS=300

# Encrypted OAuth session store. Replace the placeholder with a local Fernet key.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SCD_OAUTH_SESSION_STORE_PATH=data/oauth_sessions.enc
SCD_OAUTH_SESSION_ENCRYPTION_KEY=<fernet-key-for-local-session-store>

# Encrypted OAuth token store. Replace the placeholder with a separate local Fernet key.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SCD_OAUTH_TOKEN_STORE_PATH=data/oauth_tokens.enc
SCD_OAUTH_TOKEN_ENCRYPTION_KEY=<fernet-key-for-local-token-store>

# SoundCloud OAuth app credentials. Replace placeholders locally only.
SCD_SOUNDCLOUD_CLIENT_ID=<your-soundcloud-client-id>
SCD_SOUNDCLOUD_CLIENT_SECRET=<your-soundcloud-client-secret-if-required>

# Official SoundCloud endpoints. Do not add query strings, fragments, tokens, or credentials.
SCD_SOUNDCLOUD_API_BASE_URL=https://api.soundcloud.com
SCD_SOUNDCLOUD_AUTH_BASE_URL=https://secure.soundcloud.com

# Optional resolver override for controlled testing only.
# SCD_SOUNDCLOUD_RESOLVE_ENDPOINT=https://example.invalid/resolve
